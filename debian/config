#!/bin/bash
set -e

. /usr/share/debconf/confmodule

# Heuristic for loopback size: ceil(current journal / 5 / GiB), min 1
JOURNAL_BYTES=$(find /var/log/journal -name '*.journal' -printf '%s\n' 2>/dev/null \
                | awk '{s+=$1} END {print s+0}')
LOOPBACK_DEFAULT=$(( (JOURNAL_BYTES / 5 + (1<<30) - 1) / (1<<30) ))
[ "$LOOPBACK_DEFAULT" -lt 1 ] && LOOPBACK_DEFAULT=1

# Only seed default on first-ever install; preserve prior answer on upgrade/reconfigure
db_fget journald-archive/loopback_size_gib seen
if [ "$RET" != "true" ]; then
    db_set journald-archive/loopback_size_gib "$LOOPBACK_DEFAULT"
fi

db_input high journald-archive/loopback_size_gib || true
db_go || true

db_get journald-archive/loopback_size_gib
LOOPBACK_ANSWER=$RET
VACUUM_DEFAULT=$(( LOOPBACK_ANSWER * 5 ))

db_fget journald-archive/vacuum_size_gib seen
if [ "$RET" != "true" ]; then
    db_set journald-archive/vacuum_size_gib "$VACUUM_DEFAULT"
fi

db_input medium journald-archive/vacuum_size_gib || true
db_go || true
