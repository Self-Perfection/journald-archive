#!/usr/bin/make -f

%:
	dh $@

# Pure-data package; nothing to build/configure/test/install via auto-targets.
# Overrides are required because the top-level Makefile (build helper, not a
# build system) would otherwise be detected and invoked recursively.
override_dh_auto_clean:
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_install:

# The timer's helper lives under /usr/lib, where dh_fixperms leaves files 0644.
# It is executed directly by the service, so restore the executable bit.
override_dh_fixperms:
	dh_fixperms
	chmod 0755 debian/journald-archive/usr/lib/journald-archive/journald-archive

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start journald-archive.service
	dh_installsystemd journald-archive.timer
	# The archive mount backs a btrfs loopback the timer/service hold open;
	# remounting it on upgrade is disruptive, so leave it running untouched.
	dh_installsystemd --no-restart-on-upgrade var-log-journal_archive.mount
	# The combined union is a stateless read-only mergerfs view, so restart it
	# on upgrade — otherwise changes to its mount options (e.g. posix_acl) only
	# take effect after a reboot or a manual remount.
	dh_installsystemd var-log-journal_combined.mount
