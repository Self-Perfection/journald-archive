#!/bin/bash
set -e

. /usr/share/debconf/confmodule

ARCHIVE_FILE="/var/log/journal_archive.btrfs"
ARCHIVE_MOUNT="/var/log/journal_archive"
COMBINED_MOUNT="/var/log/journal_combined"

case "$1" in
    configure)
        db_get journald-archive/loopback_size_gib
        LOOPBACK_GIB=$RET
        db_get journald-archive/vacuum_size_gib
        VACUUM_GIB=$RET

        # The config script validates these, but guard anyway so a bad value
        # (e.g. a hand-preseeded one) fails clearly instead of as a cryptic
        # `fallocate: invalid length value` further down.
        is_positive_int() { case "$1" in ''|*[!0-9]*) return 1 ;; *[1-9]*) return 0 ;; *) return 1 ;; esac; }
        if ! is_positive_int "$LOOPBACK_GIB" || ! is_positive_int "$VACUUM_GIB"; then
            echo "journald-archive: invalid size configuration" \
                 "(loopback='$LOOPBACK_GIB', vacuum='$VACUUM_GIB')." >&2
            echo "Each must be a positive whole number of GiB." \
                 "Fix with: dpkg-reconfigure journald-archive" >&2
            exit 1
        fi

        # /var/log/journal must exist for mergerfs to use it as a branch.
        # If absent, create it with journald-style perms; this implicitly
        # enables persistent journaling on Storage=auto.
        if [ ! -d /var/log/journal ]; then
            install -d -m 2755 -o root -g systemd-journal /var/log/journal
        fi

        install -d -m 2755 -o root -g systemd-journal "$ARCHIVE_MOUNT"
        install -d -m 2755 -o root -g systemd-journal "$COMBINED_MOUNT"

        if [ ! -f "$ARCHIVE_FILE" ]; then
            fallocate -l "${LOOPBACK_GIB}GiB" "$ARCHIVE_FILE"
            chmod 600 "$ARCHIVE_FILE"
            mkfs.btrfs -q "$ARCHIVE_FILE"
        elif ! blkid -o value -s TYPE "$ARCHIVE_FILE" 2>/dev/null | grep -qx btrfs; then
            echo "WARNING: $ARCHIVE_FILE exists but is not btrfs. Leaving untouched." >&2
        fi

        # Generate runtime config only on first install. Subsequent edits stay.
        if [ ! -e /etc/default/journald-archive ]; then
            cat >/etc/default/journald-archive <<EOF
# journald-archive runtime configuration.
# This file was generated on first install from debconf answers.
# Edit freely; it will not be overwritten by package upgrades.
# To reset to debconf defaults: rm this file and run \`dpkg-reconfigure journald-archive\`.

ARCHIVE_MOUNT="$ARCHIVE_MOUNT"
ARCHIVE_FILE="$ARCHIVE_FILE"
VACUUM_SIZE_GIB=$VACUUM_GIB

# Grace period in minutes: a rotated journal is archived only once it is older
# than this. Larger values keep more recent history in the fast hot tier,
# queryable with plain \`journalctl\`. Examples: 60 = 1 hour, 1440 = 1 day.
GRACE_MINUTES=30
EOF
            chmod 644 /etc/default/journald-archive
        fi

        # Surface knobs added in later versions in an existing config, without
        # touching the user's values. Upgrades from before GRACE_MINUTES get it
        # appended with its default; the grep guard keeps this idempotent.
        if [ -e /etc/default/journald-archive ] \
           && ! grep -q '^[[:space:]]*GRACE_MINUTES=' /etc/default/journald-archive; then
            cat >>/etc/default/journald-archive <<'GRACEEOF'

# Grace period in minutes: a rotated journal is archived only once it is older
# than this. Larger values keep more recent history in the fast hot tier,
# queryable with plain `journalctl`. Examples: 60 = 1 hour, 1440 = 1 day.
GRACE_MINUTES=30
GRACEEOF
        fi
        ;;
esac

#DEBHELPER#

exit 0
