#!/bin/bash
set -e

. /usr/share/debconf/confmodule

# Prompt for a debconf string template until the answer is a positive integer.
# If the question cannot be shown (e.g. a noninteractive frontend), fall back
# to the supplied default rather than looping forever or accepting garbage.
#   $1 = template   $2 = priority   $3 = default
ask_positive_int() {
    local template="$1" priority="$2" default="$3" shown
    db_fget "$template" seen
    if [ "$RET" != "true" ]; then
        db_set "$template" "$default"
    fi
    while :; do
        if db_input "$priority" "$template"; then shown=1; else shown=0; fi
        db_go || true
        db_get "$template"
        case "$RET" in
            ''|*[!0-9]*) ;;          # empty or contains a non-digit
            *[1-9]*)     return 0 ;; # all digits and not all zero -> >= 1
        esac
        if [ "$shown" -eq 0 ]; then
            # Could not prompt (noninteractive); use a known-good value.
            db_set "$template" "$default"
            return 0
        fi
        db_input critical journald-archive/invalid_size || true
        db_go || true
        db_fset "$template" seen false
    done
}

# Heuristic for the archive's physical budget: ceil(current journal / 5 / GiB),
# min 1. Assuming a conservative 5x btrfs zstd ratio, this is roughly enough to
# hold today's journal compressed; better compression simply buys more history.
JOURNAL_BYTES=$(find /var/log/journal -name '*.journal' -printf '%s\n' 2>/dev/null \
                | awk '{s+=$1} END {print s+0}')
LOOPBACK_DEFAULT=$(( (JOURNAL_BYTES / 5 + (1<<30) - 1) / (1<<30) ))
[ "$LOOPBACK_DEFAULT" -lt 1 ] && LOOPBACK_DEFAULT=1

ask_positive_int journald-archive/loopback_size_gib high "$LOOPBACK_DEFAULT"
