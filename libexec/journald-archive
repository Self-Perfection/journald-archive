#!/bin/bash
set -euo pipefail

# shellcheck source=/dev/null
. /etc/default/journald-archive

: "${ARCHIVE_MOUNT:?ARCHIVE_MOUNT not set in /etc/default/journald-archive}"

# Grace period (minutes): a rotated file is archived only once it is older
# than this. Larger values keep more recent history in the fast hot tier;
# it also avoids racing journald right after rotation. Defaults to 30 to match
# the timer interval, so a file is archived only after surviving a full cycle.
GRACE_MINUTES="${GRACE_MINUTES:-30}"
case "$GRACE_MINUTES" in
    ''|*[!0-9]*)
        echo "GRACE_MINUTES must be a non-negative integer (got '$GRACE_MINUTES')" >&2
        exit 1
        ;;
esac

if ! mountpoint -q -- "$ARCHIVE_MOUNT"; then
    echo "$ARCHIVE_MOUNT is not a mount point — aborting to avoid writing onto rootfs" >&2
    exit 1
fi

# Pull one field out of `btrfs filesystem usage -b` (raw bytes). "Free
# (estimated)" accounts for chunk/metadata overhead better than df does.
btrfs_usage_field() {
    btrfs filesystem usage -b "$ARCHIVE_MOUNT" 2>/dev/null \
        | grep -oP "$1"':\s+\K[0-9]+' | head -1
}

# Free margin (MiB) to keep available so incoming journals have room without
# hitting ENOSPC. Falls back to ~1/16 of the archive size if unset (e.g. a
# config predating the option that has not been migrated yet).
TOTAL_BYTES=$(btrfs_usage_field 'Device size' || true)
FREE_MARGIN_MIB="${FREE_MARGIN_MIB:-}"
if [ -z "$FREE_MARGIN_MIB" ]; then
    FREE_MARGIN_MIB=$(( ${TOTAL_BYTES:-0} / 1048576 / 16 ))
fi
case "$FREE_MARGIN_MIB" in
    ''|*[!0-9]*)
        echo "FREE_MARGIN_MIB must be a non-negative integer (got '$FREE_MARGIN_MIB')" >&2
        exit 1
        ;;
esac
margin_bytes=$(( FREE_MARGIN_MIB * 1048576 ))

# Never let a misconfigured margin wipe the whole archive: cap it at half the
# device, otherwise the eviction loop below could delete everything chasing an
# unreachable target.
if [ -n "${TOTAL_BYTES:-}" ] && [ "$margin_bytes" -gt $(( TOTAL_BYTES / 2 )) ]; then
    echo "journald-archive: FREE_MARGIN_MIB (${FREE_MARGIN_MIB} MiB) exceeds half the archive; capping" >&2
    margin_bytes=$(( TOTAL_BYTES / 2 ))
fi

MACHINE_ID=$(cat /etc/machine-id)
SRC="/var/log/journal/$MACHINE_ID"
DST="$ARCHIVE_MOUNT/$MACHINE_ID"

[ -d "$SRC" ] || exit 0

if [ ! -d "$DST" ]; then
    install -d -m 2755 -o root -g systemd-journal "$DST"
fi

# Eviction: drop the oldest archived journals until at least FREE_MARGIN_MIB is
# free. We re-read free space after each delete, but btrfs frees extents only on
# transaction commit, so `btrfs filesystem sync` forces the accounting to settle
# before we look again — otherwise the lagging counter would make us over-evict.
# (st_blocks/du can't substitute here: on btrfs they report the uncompressed
# size, not the compressed on-disk usage, so we cannot account for freed space
# ourselves — the filesystem is the only source of truth.)
while :; do
    free=$(btrfs_usage_field 'Free \(estimated\)')
    if [ -z "$free" ]; then
        echo "journald-archive: could not read archive free space; skipping eviction" >&2
        break
    fi
    [ "$free" -ge "$margin_bytes" ] && break

    # Oldest archived journal by mtime. Capture the whole sorted list and take
    # its first line in the shell — NOT `... | sort -n | head -1`: under
    # `set -o pipefail`, head closing the pipe after one line makes sort exit on
    # SIGPIPE (141) once the listing outgrows the pipe buffer, and `set -e` would
    # then abort the script here, before anything is ever evicted.
    listing=$(find "$ARCHIVE_MOUNT" -type f -name '*@*.journal' -printf '%T@ %p\n' \
              2>/dev/null | sort -n)
    oldest=${listing%%$'\n'*}   # first (oldest) line, or "" if none
    oldest=${oldest#* }         # strip the "<mtime> " prefix, leaving the path
    [ -n "$oldest" ] || break   # nothing left to evict

    rm -f -- "$oldest"
    btrfs filesystem sync "$ARCHIVE_MOUNT" >/dev/null
done

# Move sealed, rotated journals (name contains '@', never the active
# system.journal) older than the grace period into the archive. A failed move
# is almost always ENOSPC; clean up any partial copy and retry next run rather
# than leaving a truncated journal that journalctl would choke on.
#
# Oldest first (by mtime): if not everything fits this run, the leftovers stay
# in the hot tier, where journald evicts the oldest first — so archive the
# most-at-risk (oldest) files before journald can drop them.
while IFS= read -r -d '' f; do
    base=${f##*/}
    if ! mv -n -- "$f" "$DST/$base"; then
        rm -f -- "$DST/$base"
        echo "journald-archive: could not archive $base (likely out of space); will retry" >&2
    fi
done < <(find "$SRC" -maxdepth 1 -type f -name '*@*.journal' -mmin +"$GRACE_MINUTES" \
             -printf '%T@\t%p\0' | sort -zn | cut -z -f2-)
